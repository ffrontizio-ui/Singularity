# Server Configuration
HOST_PORT=8000

# عنوان بروكسي تور (سيتصل باسم خدمة tor في دوكر)
TOR_PROXY=socks5://tor:9050

# تشفير الهوية (مفتاح سري عشوائي)
SECRET_KEY=generate_a_random_secret_here

# محفظة البيتكوين (BIP84 Master Public Key) لكشف العناوين فقط
# احصل عليه من محفظتك (يبدأ بـ zpub)
MASTER_BTC_ZPUB=zpub_your_public_master_key_here

# عنوان البيتكوين لاستقبال الدعم للمشروع
PROJECT_BTC_ADDRESS=bc1q_your_public_address_here

# رابط خدمة المعاينة (Preview Microservice)
PREVIEWER_URL=http://previewer:8001
